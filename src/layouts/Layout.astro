---
import "../styles/main.scss";
import robotoFlexFontUrl from "../fonts/generated/font-0.woff2?url";

if (import.meta.env.DEV) {
    void import("../styles/debug-layout.scss");
}

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preload" href={robotoFlexFontUrl} as="font" type="font/woff2" crossorigin />
        <meta name="description" content="Personal site of Connor Low, a Senior Software Engineer in Seattle. Technical deep dives into AEM, .NET, Node.js, and performant applications.">
        <title>{title}</title>
    </head>
    <body>
        <div class="page__background-canvas-container">
            <cmp-cgol-sim width="5120" height="5120" scale="2"></cmp-cgol-sim>
        </div>
        <div class="content-wrapper">
            <slot />
        </div>

        <script>
            void import("../components/GameOfLifeSimulation/GameOfLifeSimulation");
        </script>
    </body>
</html>
