{
  "name": "green-gamma",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run generate:style-tokens && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate:style-tokens": "node --experimental-strip-types ./scripts/generate-style-tokens.ts",
    "generate:style-tokens:watch": "npx nodemon --watch \"src/styles/tokens\" --ext ts,js,mjs,cjs,json --exec \"npm run generate:style-tokens\"",
    "wasm:as:build": "npm run asbuild:debug --prefix wasm/as && npm run asbuild:release --prefix wasm/as",
    "wasm:as:dev": "npm run start --prefix wasm/as"
  },
  "dependencies": {
    "astro": "^6.1.3",
    "sass": "^1.99.0",
    "texsaur": "^1.0.7",
    "wasm-as": "file:wasm/as"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.0",
    "assemblyscript": "^0.28.13",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "typescript-eslint": "^8.58.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  }
}
